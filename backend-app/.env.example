AZURE_OPENAI_API_KEY="your-azure-openai-key-here"
AZURE_OPENAI_ENDPOINT="https://your-resource-name.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4"
AZURE_OPENAI_API_VERSION="2023-05-15"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maritime"

# Anthropic settings
ANTHROPIC_API_KEY="your-anthropic-key-here"
ANTHROPIC_MODEL="claude-3-opus-20240229"

# Gemini settings
GEMINI_API_KEY="your-gemini-key-here"
GEMINI_MODEL="gemini-1.5-pro"

# Azure Storage settings (for survey templates)
# Configure either AZURE_STORAGE_CONNECTION_STRING or AZURE_STORAGE_ACCOUNT_NAME + AZURE_STORAGE_ACCOUNT_KEY
AZURE_STORAGE_CONNECTION_STRING="your-azure-storage-connection-string-here"
AZURE_STORAGE_ACCOUNT_NAME="your-azure-storage-account-name-here"
AZURE_STORAGE_ACCOUNT_KEY="your-azure-storage-account-key-here"
AZURE_STORAGE_CONTAINER_TEMPLATES="survey-templates"
AZURE_STORAGE_CONTAINER_IMAGES="survey-images"
AZURE_STORAGE_CONTAINER_REPORTS="survey-reports"
